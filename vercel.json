{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "trailingSlash": false,
    
    "routes": [
        {
            "src": "^/$",
            "status": 307,
            "headers": { "Location": "/beta" },
            "continue": true
        },
        {
            "src": "^/beta(.*)",
            "dest": "$1"
        },
        {
            "src": "^(?!/beta).*",
            "status": 404
        }
    ]
}